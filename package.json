{
  "name": "@tanstack/highlight",
  "version": "0.0.4",
  "description": "Tiny class-based syntax highlighting for documentation.",
  "keywords": [
    "syntax-highlighting",
    "markdown",
    "documentation",
    "ssr",
    "typescript"
  ],
  "type": "module",
  "license": "MIT",
  "author": "TanStack",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TanStack/highlight.git"
  },
  "homepage": "https://github.com/TanStack/highlight#readme",
  "bugs": {
    "url": "https://github.com/TanStack/highlight/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@11.4.0",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./core": {
      "types": "./dist/core.d.ts",
      "import": "./dist/core.js",
      "default": "./dist/core.js"
    },
    "./languages": {
      "types": "./dist/languages/index.d.ts",
      "import": "./dist/languages/index.js",
      "default": "./dist/languages/index.js"
    },
    "./languages/*": {
      "types": "./dist/languages/*.d.ts",
      "import": "./dist/languages/*.js",
      "default": "./dist/languages/*.js"
    },
    "./theme": {
      "types": "./dist/theme.d.ts",
      "import": "./dist/theme.js",
      "default": "./dist/theme.js"
    },
    "./themes/*": {
      "types": "./dist/themes/*.d.ts",
      "import": "./dist/themes/*.js",
      "default": "./dist/themes/*.js"
    },
    "./markdown": {
      "types": "./dist/markdown.d.ts",
      "import": "./dist/markdown.js",
      "default": "./dist/markdown.js"
    },
    "./rehype": {
      "types": "./dist/rehype.d.ts",
      "import": "./dist/rehype.js",
      "default": "./dist/rehype.js"
    },
    "./remark": {
      "types": "./dist/remark.d.ts",
      "import": "./dist/remark.js",
      "default": "./dist/remark.js"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.js",
      "default": "./dist/react.js"
    }
  },
  "scripts": {
    "bench": "node scripts/bench.mjs",
    "build": "node scripts/clean.mjs && tsc -p tsconfig.build.json",
    "compare:shiki": "pnpm run build && node scripts/compare-shiki.mjs",
    "compare:sugar-high": "pnpm run build && node scripts/compare-sugar-high.mjs",
    "extract:fixtures": "node scripts/extract-doc-fixtures.mjs",
    "lint:package": "publint",
    "prepublishOnly": "pnpm run verify",
    "report:compare": "pnpm run build && node scripts/generate-visual-compare.mjs",
    "scan:languages": "node scripts/scan-languages.mjs",
    "size": "node scripts/measure-size.mjs",
    "test": "vitest run",
    "test:package": "node scripts/test-package.mjs",
    "typecheck": "tsc --noEmit",
    "verify": "pnpm run typecheck && pnpm run build && pnpm run lint:package && pnpm run test:package && pnpm run test && pnpm run size && pnpm run bench"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "esbuild": "^0.28.1",
    "mdast-util-to-hast": "^13.2.1",
    "publint": "^0.3.21",
    "shiki": "^4.3.1",
    "sugar-high": "^1.2.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
